{
  "name": "remainder",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/remainder/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/remainder", "command": "pnpm dev" }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/remainder", "command": "pnpm build" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "cwd": "apps/remainder", "command": "pnpm typecheck" }
    }
  }
}
